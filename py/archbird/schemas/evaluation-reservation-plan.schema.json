{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/evaluation-reservation-plan.schema.json",
  "title": "Archbird evaluation repository reservation plan",
  "description": "An asserted repository-level validation and held-out split selected before source or history inspection.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact", "provenance", "selection_rule", "repositories"],
  "properties": {
    "schema_version": {"const": 1},
    "artifact": {"const": "archbird-evaluation-reservation-plan"},
    "provenance": {"const": "asserted"},
    "selection_rule": {"type": "string", "minLength": 1},
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/repository"}
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "primary_language", "split", "inspection_policy", "rationale"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "url": {"type": "string", "minLength": 1},
        "primary_language": {"type": "string", "minLength": 1},
        "split": {"enum": ["validation", "held_out"]},
        "inspection_policy": {"enum": ["open_after_reservation", "sealed_until_scoring"]},
        "rationale": {"type": "string", "minLength": 1}
      }
    }
  }
}
