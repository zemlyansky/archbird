{
  "schema_version": 1,
  "suite": "demo-architecture",
  "description": "Reviewed public surface and test-route requirements.",
  "projects": {
    "subject": {"config": "archbird.json"}
  },
  "extractors": {
    "required.core_api": {
      "kind": "literal_set",
      "values": ["demo_close", "demo_open"]
    },
    "actual.core_api": {
      "kind": "symbols",
      "project": "subject",
      "layer": "core",
      "paths": ["include/demo.h"],
      "public_only": true
    },
    "actual.python_tests": {
      "kind": "test_routes",
      "project": "subject",
      "group": "python"
    }
  },
  "checks": [
    {
      "id": "CORE-PUBLIC-API",
      "assert": "required_subset",
      "severity": "error",
      "owner": "core",
      "rationale": "Both supported native entrypoints must remain public.",
      "requirement": "ARCH-CORE-001",
      "expected": "required.core_api",
      "actual": "actual.core_api"
    },
    {
      "id": "PYTHON-CORE-ROUTE",
      "assert": "min_test_routes",
      "severity": "error",
      "owner": "python",
      "rationale": "At least one configured Python case must route to the core.",
      "requirement": "TEST-PY-001",
      "actual": "actual.python_tests",
      "min": 1,
      "required_routes": ["src/core.c"]
    }
  ]
}
