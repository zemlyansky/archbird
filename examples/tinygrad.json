{
  "schema_version": 2,
  "project": "tinygrad-reference",
  "description": "Canonical tinygrad Python compiler/runtime sources used as a Polygrad architecture reference.",
  "exclude": [
    "tinygrad/runtime/autogen/**",
    "tinygrad/viz/assets/**",
    "**/__pycache__/**"
  ],
  "layers": [
    {
      "name": "core",
      "role": "reference",
      "language": "python",
      "globs": ["tinygrad/**/*.py"],
      "import_roots": ["."]
    }
  ],
  "packages": [
    {
      "name": "python",
      "kind": "python",
      "path": "tinygrad/__init__.py",
      "layer": "core",
      "identity": "tinygrad",
      "entries": ["tinygrad/__init__.py"]
    }
  ],
  "components": [
    {"name": "ir", "paths": ["tinygrad/uop/**/*.py"], "description": "UOp IR, patterns, validation, and symbolic algebra"},
    {"name": "tensor", "paths": ["tinygrad/tensor.py", "tinygrad/function.py", "tinygrad/mixin/**/*.py"], "description": "tensor API and operation mixins"},
    {"name": "autograd", "paths": ["tinygrad/mixin/gradient.py"], "description": "gradient construction"},
    {"name": "schedule", "paths": ["tinygrad/schedule/**/*.py"], "description": "schedule and range/index lowering"},
    {"name": "realize", "paths": ["tinygrad/engine/realize.py"], "description": "schedule execution and realization"},
    {"name": "codegen", "paths": ["tinygrad/codegen/**/*.py", "tinygrad/renderer/**/*.py"], "description": "optimization, linearization, and rendering"},
    {"name": "runtime", "paths": ["tinygrad/device.py", "tinygrad/runtime/*.py", "tinygrad/runtime/graph/**/*.py", "tinygrad/runtime/support/**/*.py"], "description": "device and runtime execution"},
    {"name": "jit", "paths": ["tinygrad/engine/jit.py"], "description": "capture and replay"},
    {"name": "frontends", "paths": ["tinygrad/__init__.py", "tinygrad/nn/**/*.py"], "description": "public Python and neural-network surfaces"}
  ],
  "constraints": {
    "REQUIRED-MAPPED-PATHS": {
      "kind": "required_paths",
      "paths": [
        "tinygrad/uop/ops.py",
        "tinygrad/tensor.py",
        "tinygrad/engine/realize.py",
        "tinygrad/engine/jit.py"
      ],
      "owner": "architecture",
      "rationale": "Reviewed source paths remain inside the configured Map scope."
    },
    "REQUIRED-SYMBOLS-CORE": {
      "kind": "required_symbols",
      "layer": "core",
      "symbols": [
        "Tensor",
        "UOp"
      ],
      "owner": "architecture",
      "rationale": "Reviewed core symbols remain present."
    }
  }
}
