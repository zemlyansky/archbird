  "checks": [
    {
      "id": "NATIVE-COMPONENT-EDGES",
      "assert": "allowed_edges",
      "severity": "error",
      "owner": "native-core",
      "rationale": "The I/O-free core may depend on its pinned parser; tests may depend on the core, never the reverse.",
      "requirement": "ARCHBIRD-NATIVE-ARCH-001",
      "expected": "architecture.allowed",
      "actual": "architecture.actual"
    },
    {
      "id": "NATIVE-COMPONENT-ACYCLIC",
      "assert": "acyclic",
      "severity": "error",
      "owner": "native-core",
      "rationale": "The native component graph must remain acyclic while subsystems are ported incrementally.",
      "requirement": "ARCHBIRD-NATIVE-ARCH-001",
      "actual": "architecture.actual"
    },
    {
      "id": "NATIVE-JSON-TEST-ROUTE",
      "assert": "min_test_routes",
      "severity": "error",
      "owner": "native-core",
      "rationale": "The native JSON implementation must remain statically connected to a native regression host.",
      "requirement": "ARCHBIRD-NATIVE-JSON-001",
      "actual": "core.tests",
      "min": 1,
      "required_routes": ["src/base/json.c"]
    }
