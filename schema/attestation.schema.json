{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/attestation.schema.json",
  "title": "Archbird project-owned behavioral attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite", "producer", "profile", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "suite": {"type": "string", "minLength": 1},
    "producer": {"$ref": "#/$defs/producer"},
    "profile": {"$ref": "#/$defs/profile"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "scalar": {
      "type": ["null", "boolean", "integer", "number", "string"]
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/scalar"}
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "sha256"],
      "properties": {
        "role": {"type": "string", "minLength": 1},
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$)).+"
        },
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "map_input_sha256", "evidence", "evidence_slice_sha256"],
      "properties": {
        "project": {"type": "string", "minLength": 1},
        "revision": {"type": "string"},
        "map_input_sha256": {"$ref": "#/$defs/sha256"},
        "evidence": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/evidence"},
          "allOf": [
            {
              "contains": {
                "type": "object",
                "properties": {"role": {"const": "runner"}},
                "required": ["role"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {"role": {"const": "case_bundle"}},
                "required": ["role"]
              }
            },
            {
              "contains": {
                "type": "object",
                "properties": {"role": {"const": "subject"}},
                "required": ["role"]
              }
            }
          ]
        },
        "evidence_slice_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "capabilities": {"$ref": "#/$defs/strings"},
        "parameters": {"$ref": "#/$defs/parameters"}
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {"enum": ["exact", "exact_bits", "float"]},
        "atol": {"type": "number", "minimum": 0},
        "rtol": {"type": "number", "minimum": 0},
        "max_ulp": {"type": "integer", "minimum": 0},
        "nan_equal": {"type": "boolean"},
        "signed_zero_equal": {"type": "boolean"}
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "kind"],
      "properties": {
        "phase": {"type": "string", "minLength": 1},
        "kind": {
          "enum": ["ok", "error", "rejected", "trap", "unlinkable", "exhaustion", "timeout", "unsupported"]
        },
        "type": {"type": "string"},
        "value": {}
      },
      "if": {"properties": {"kind": {"const": "ok"}}},
      "then": {"required": ["value"]},
      "else": {"not": {"required": ["value"]}}
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "outcome"],
      "properties": {
        "route": {"type": "string", "minLength": 1},
        "outcome": {"$ref": "#/$defs/outcome"}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "input", "observations"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "requirements": {"$ref": "#/$defs/strings"},
        "input": {},
        "requires": {"$ref": "#/$defs/strings"},
        "requires_parameters": {"$ref": "#/$defs/parameters"},
        "comparison": {"$ref": "#/$defs/comparison"},
        "observations": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/observation"}
        }
      }
    }
  }
}
