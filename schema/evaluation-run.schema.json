{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/evaluation-run.schema.json",
  "title": "Archbird historical-change evaluation run",
  "description": "Immutable observed metrics and enforced cache policy from one Archbird executable over one frozen evaluation corpus.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "provenance",
    "corpus_sha256",
    "label",
    "evaluator",
    "cache_policy",
    "host",
    "tool",
    "cases",
    "aggregate"
  ],
  "properties": {
    "schema_version": {"const": 2},
    "artifact": {"const": "archbird-evaluation-run"},
    "provenance": {"const": "observed"},
    "corpus_sha256": {"$ref": "#/$defs/sha256"},
    "cache_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider_cache"],
      "properties": {
        "provider_cache": {
          "type": "object",
          "additionalProperties": false,
          "required": ["initial_state", "max_bytes", "mode", "reuse"],
          "properties": {
            "initial_state": {"const": "empty"},
            "max_bytes": {"type": "integer", "minimum": 1},
            "mode": {"const": "isolated_per_case"},
            "reuse": {"const": "before_and_after_revision"}
          }
        }
      }
    },
    "held_out_opened": {"type": "boolean"},
    "label": {"type": "string", "minLength": 1},
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_sha256"],
      "properties": {
        "implementation_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "host": {"type": "object"},
    "tool": {"type": "object"},
    "cases": {"type": "array", "items": {"type": "object"}},
    "aggregate": {"type": "object"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
