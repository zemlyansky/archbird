{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/evaluation-case.schema.json",
  "title": "Archbird historical-change evaluation case",
  "description": "One pinned before/after repository change with asserted relevance truth. Repository bytes and run artifacts remain external to the source distribution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "provenance",
    "id",
    "split",
    "repository",
    "task",
    "analysis",
    "ground_truth",
    "review"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact": {"const": "archbird-evaluation-case"},
    "provenance": {"const": "asserted"},
    "id": {"$ref": "#/$defs/id"},
    "split": {"enum": ["development", "validation", "held_out"]},
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "url", "before_revision", "after_revision"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "url": {"type": "string", "minLength": 1},
        "before_revision": {"$ref": "#/$defs/revision"},
        "after_revision": {"$ref": "#/$defs/revision"}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "source"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "source": {"type": "string", "minLength": 1}
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["track", "selectors", "seed_rationale", "depth", "test_depth"],
      "properties": {
        "track": {"enum": ["exact_query", "exact_impact"]},
        "selectors": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "value"],
            "properties": {
              "kind": {"enum": ["path", "symbol", "test"]},
              "value": {"type": "string", "minLength": 1}
            }
          }
        },
        "seed_rationale": {
          "description": "Why the selector follows from the task-facing identity rather than the reviewed implementation diff.",
          "type": "string",
          "minLength": 1
        },
        "depth": {"type": "integer", "minimum": 0, "maximum": 16},
        "test_depth": {"type": "integer", "minimum": 0, "maximum": 16},
        "config": {"type": ["object", "null"]}
      }
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relevant_files",
        "relevant_symbols",
        "relevant_tests",
        "architecture_obligations",
        "notes"
      ],
      "properties": {
        "relevant_files": {"$ref": "#/$defs/paths"},
        "relevant_symbols": {"$ref": "#/$defs/strings"},
        "relevant_tests": {"$ref": "#/$defs/strings"},
        "introduced_tests": {
          "description": "After-only test selectors introduced by the change. These are Act obligations, not before-state retrieval truth.",
          "$ref": "#/$defs/strings"
        },
        "architecture_obligations": {"$ref": "#/$defs/strings"},
        "notes": {"type": "string"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "rationale"],
      "properties": {
        "status": {"enum": ["candidate", "reviewed"]},
        "rationale": {"type": "string", "minLength": 1},
        "reviewer": {"type": "string", "minLength": 1},
        "evidence": {"$ref": "#/$defs/strings"}
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "revision": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^\\u0000]+$"
    },
    "paths": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/path"}
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
