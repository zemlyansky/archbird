{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/verification.schema.json",
  "title": "Archbird deterministic architecture verification suite",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "suite", "projects", "extractors", "checks"],
  "properties": {
    "schema_version": {"const": 1},
    "suite": {"$ref": "#/$defs/id"},
    "description": {"type": "string"},
    "candidate": {"type": "boolean"},
    "policy_date": {"type": "string", "format": "date"},
    "projects": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/project"}
    },
    "extractors": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/extractor"}
    },
    "mappings": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/mapping"}
    },
    "attestations": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/id"},
      "additionalProperties": {"$ref": "#/$defs/attestation"}
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/check"}
    },
    "waivers": {
      "type": "array",
      "items": {"$ref": "#/$defs/waiver"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "strings": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "scalar": {
      "type": ["null", "boolean", "integer", "number", "string"]
    },
    "portablePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:[\\\\/]).+"
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(^|/)\\.\\.(/|$)).+"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config": {"$ref": "#/$defs/portablePath"},
        "map": {"$ref": "#/$defs/portablePath"},
        "root": {"$ref": "#/$defs/portablePath"},
        "revision": {"type": "string"},
        "source_lock": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {"$ref": "#/$defs/repositoryPath"},
          "additionalProperties": {"$ref": "#/$defs/sha256"}
        },
        "profile": {"type": "string", "minLength": 1},
        "capabilities": {"$ref": "#/$defs/strings"},
        "parameters": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/scalar"}
        }
      },
      "oneOf": [
        {"required": ["config"], "not": {"required": ["map"]}},
        {"required": ["map"], "not": {"required": ["config"]}}
      ]
    },
    "relationRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "target"],
      "properties": {
        "source": {"type": "string", "minLength": 1},
        "target": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "minLength": 1, "default": "*"}
      }
    },
    "extractor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "python_enum",
            "python_set",
            "c_enum",
            "c_designated_initializer",
            "c_macro_set",
            "symbols",
            "file_edges",
            "component_edges",
            "test_routes",
            "provider_surface",
            "literal_set",
            "literal_values",
            "literal_relation"
          ]
        },
        "project": {"$ref": "#/$defs/id"},
        "path": {"$ref": "#/$defs/repositoryPath"},
        "class": {"type": "string", "minLength": 1},
        "attribute": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "call": {"type": "string", "minLength": 1},
        "selector_argument": {"type": "integer", "minimum": 0},
        "selector": {"type": "string", "minLength": 1},
        "values_from_argument": {"type": "integer", "minimum": 0},
        "auto_start": {"type": "integer", "minimum": 0},
        "strip_prefix": {"type": "string"},
        "strip_suffix": {"type": "string"},
        "include": {"$ref": "#/$defs/strings"},
        "exclude": {"$ref": "#/$defs/strings"},
        "layer": {"type": "string", "minLength": 1},
        "paths": {"$ref": "#/$defs/strings"},
        "kinds": {"$ref": "#/$defs/strings"},
        "from_paths": {"$ref": "#/$defs/strings"},
        "to_paths": {"$ref": "#/$defs/strings"},
        "group": {"type": "string", "minLength": 1},
        "selectors": {"$ref": "#/$defs/strings"},
        "configured_only": {"type": "boolean"},
        "public_only": {"type": "boolean"},
        "values": {
          "oneOf": [
            {"$ref": "#/$defs/strings"},
            {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/scalar"}
            }
          ]
        },
        "rows": {
          "type": "array",
          "items": {"$ref": "#/$defs/relationRow"}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"kind": {"enum": ["python_enum", "python_set", "c_enum", "c_designated_initializer", "c_macro_set"]}}},
          "then": {"required": ["project", "path"]}
        },
        {
          "if": {"properties": {"kind": {"const": "python_enum"}}},
          "then": {"required": ["class"]}
        },
        {
          "if": {"properties": {"kind": {"const": "python_set"}}},
          "then": {"required": ["class", "attribute"]}
        },
        {
          "if": {"properties": {"kind": {"enum": ["c_enum", "c_designated_initializer"]}}},
          "then": {"required": ["name"]}
        },
        {
          "if": {"properties": {"kind": {"const": "c_macro_set"}}},
          "then": {"required": ["call", "selector"]}
        },
        {
          "if": {"properties": {"kind": {"enum": ["symbols", "file_edges", "component_edges", "test_routes"]}}},
          "then": {"required": ["project"]}
        },
        {
          "if": {"properties": {"kind": {"const": "provider_surface"}}},
          "then": {"required": ["project", "name"]}
        },
        {
          "if": {"properties": {"kind": {"enum": ["literal_set", "literal_values"]}}},
          "then": {"required": ["values"]}
        },
        {
          "if": {"properties": {"kind": {"const": "literal_relation"}}},
          "then": {"required": ["rows"]}
        }
      ]
    },
    "mapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "actual_to_expected": {
          "type": "object",
          "additionalProperties": {"type": "string", "minLength": 1}
        }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "path"],
      "properties": {
        "project": {"$ref": "#/$defs/id"},
        "path": {"$ref": "#/$defs/portablePath"}
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "assert", "owner", "rationale"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "assert": {
          "enum": [
            "set_equal",
            "mapped_set_equal",
            "values_equal",
            "mapped_values_equal",
            "subset",
            "required_subset",
            "required_values",
            "cardinality",
            "required_edges",
            "forbidden_edges",
            "allowed_edges",
            "acyclic",
            "min_test_routes",
            "attestation_equal"
          ]
        },
        "severity": {"enum": ["error", "warning", "note"]},
        "owner": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "requirement": {
          "oneOf": [
            {"type": "string", "minLength": 1},
            {"$ref": "#/$defs/strings"}
          ]
        },
        "tags": {"$ref": "#/$defs/strings"},
        "expected": {"$ref": "#/$defs/id"},
        "actual": {"$ref": "#/$defs/id"},
        "mapping": {"$ref": "#/$defs/id"},
        "min": {"type": "integer", "minimum": 0},
        "max": {"type": "integer", "minimum": 0},
        "exact": {"type": "integer", "minimum": 0},
        "required_routes": {"$ref": "#/$defs/strings"},
        "reference_route": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"assert": {"enum": ["set_equal", "mapped_set_equal", "values_equal", "mapped_values_equal", "subset", "required_subset", "required_values", "required_edges", "forbidden_edges", "allowed_edges", "attestation_equal"]}}},
          "then": {"required": ["expected", "actual"]}
        },
        {
          "if": {"properties": {"assert": {"enum": ["mapped_set_equal", "mapped_values_equal"]}}},
          "then": {"required": ["mapping"]}
        },
        {
          "if": {"properties": {"assert": {"enum": ["cardinality", "acyclic", "min_test_routes"]}}},
          "then": {"required": ["actual"]}
        },
        {
          "if": {"properties": {"assert": {"const": "min_test_routes"}}},
          "then": {"required": ["min"]}
        }
      ]
    },
    "waiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "owner", "rationale"],
      "properties": {
        "id": {"$ref": "#/$defs/id"},
        "check": {"$ref": "#/$defs/id"},
        "fingerprint": {"$ref": "#/$defs/sha256"},
        "comparison": {"enum": ["equal", "missing", "extra", "different"]},
        "key": {"type": "string", "minLength": 1},
        "owner": {"type": "string", "minLength": 1},
        "rationale": {"type": "string", "minLength": 1},
        "expires_on": {"type": "string", "format": "date"},
        "until_inputs": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/sha256"}
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["fingerprint"],
              "not": {
                "anyOf": [
                  {"required": ["check"]},
                  {"required": ["comparison"]},
                  {"required": ["key"]}
                ]
              }
            },
            {
              "required": ["check", "comparison", "key"],
              "not": {"required": ["fingerprint"]}
            }
          ]
        },
        {
          "anyOf": [
            {"required": ["expires_on"]},
            {"required": ["until_inputs"]}
          ]
        }
      ]
    }
  }
}
