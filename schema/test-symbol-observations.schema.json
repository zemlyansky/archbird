{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zemlyansky/archbird/raw/main/schema/test-symbol-observations.schema.json",
  "title": "Archbird observed test-to-symbol evidence",
  "description": "Strict project-runner evidence that identified test cases entered identified mapped symbols. The artifact does not claim behavioral correctness or coverage completeness. Arrays are additionally required by the native decoder to be sorted and unique by their documented identity fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "provenance",
    "project",
    "producer",
    "source",
    "cases"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "artifact": {"const": "archbird-test-symbol-observations"},
    "provenance": {"const": "observed"},
    "project": {"$ref": "#/$defs/id"},
    "producer": {"$ref": "#/$defs/producer"},
    "source": {"$ref": "#/$defs/source"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/case"}
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^\\u0000]+$"
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "implementation_sha256",
        "configuration_sha256"
      ],
      "properties": {
        "name": {"$ref": "#/$defs/id"},
        "version": {"type": "string", "minLength": 1},
        "implementation_sha256": {"$ref": "#/$defs/sha256"},
        "configuration_sha256": {"$ref": "#/$defs/sha256"},
        "input_sha256": {
          "description": "Digest of the exact project-owned runner report bytes consumed by an adapter.",
          "$ref": "#/$defs/sha256"
        },
        "runtime": {"type": "string", "minLength": 1}
      }
    },
    "sourceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "path", "sha256"],
      "properties": {
        "role": {
          "enum": ["runner", "subject", "test_inventory"]
        },
        "path": {"$ref": "#/$defs/repositoryPath"},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config_sha256",
        "map_input_sha256",
        "evidence_slice_sha256",
        "evidence"
      ],
      "properties": {
        "config_sha256": {"$ref": "#/$defs/sha256"},
        "map_input_sha256": {"$ref": "#/$defs/sha256"},
        "evidence_slice_sha256": {"$ref": "#/$defs/sha256"},
        "evidence": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/sourceEvidence"},
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["role"],
                "properties": {"role": {"const": "runner"}}
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["role"],
                "properties": {"role": {"const": "subject"}}
              },
              "minContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["role"],
                "properties": {"role": {"const": "test_inventory"}}
              },
              "minContains": 1
            }
          ]
        }
      }
    },
    "symbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "symbol", "hits"],
      "properties": {
        "path": {"$ref": "#/$defs/repositoryPath"},
        "symbol": {"type": "string", "minLength": 1},
        "hits": {"type": "integer", "minimum": 1}
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group", "path", "selector", "symbols"],
      "properties": {
        "group": {"type": "string", "minLength": 1},
        "path": {"$ref": "#/$defs/repositoryPath"},
        "selector": {"type": "string", "minLength": 1},
        "symbols": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/symbol"}
        }
      }
    }
  }
}
