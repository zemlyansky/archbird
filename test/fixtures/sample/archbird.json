{
  "schema_version": 2,
  "project": "sample",
  "description": "Integration fixture.",
  "layers": [
    {"name": "core", "role": "core", "language": "c", "globs": ["src/**/*.c", "src/**/*.h"], "public_headers": ["src/core.h"]},
    {"name": "python", "role": "frontend", "language": "python", "globs": ["py/sample/**/*.py"], "import_roots": ["py"]},
    {"name": "javascript", "role": "frontend", "language": "javascript", "globs": ["js/**/*.js"]},
    {"name": "vue", "role": "frontend", "language": "vue", "globs": ["ui/**/*.vue"]},
    {"name": "native", "role": "bridge", "language": "c", "globs": ["native/**/*.c"]}
  ],
  "packages": [
    {"name": "python", "kind": "python", "path": "pyproject.toml", "layer": "python", "entries": ["py/sample/__init__.py"]},
    {"name": "npm", "kind": "npm", "path": "package.json", "layer": "javascript", "entries": ["js/index.js"]}
  ],
  "builds": [
    {"name": "make", "kind": "make", "path": "Makefile"},
    {"name": "npm", "kind": "npm", "path": "package.json"}
  ],
  "artifacts": [
    {
      "name": "browser-bundle",
      "output": "dist/sample.js",
      "inputs": ["js/index.js", "js/runtime.js"],
      "loaded_by": [
        {"paths": ["ui/index.html"], "pattern": "dist/sample\\.js"}
      ],
      "builds": [{"source": "Makefile", "target": "dist/sample.js"}]
    }
  ],
  "bridges": [
    {"name": "python-abi", "kind": "abi", "from": "python", "to": "core", "prefixes": ["core_"]},
    {
      "name": "js-abi",
      "kind": "abi",
      "from": "javascript",
      "to": "core",
      "prefixes": ["core_"],
      "providers": [
        {
          "kind": "make_variable",
          "path": "Makefile",
          "variable": "WASM_EXPORTS",
          "pattern": "_?(core_[A-Za-z0-9_]+)"
        },
        {
          "kind": "file_pattern",
          "path": "src/core.h",
          "pattern": "\\b(core_[A-Za-z0-9_]+)\\s*\\("
        }
      ]
    },
    {
      "name": "js-binding",
      "kind": "binding",
      "from": "javascript",
      "to": "native",
      "prefixes": ["core_"],
      "providers": [
        {"kind": "exports", "path": "native/addon.c"}
      ]
    },
    {"name": "worker", "kind": "message", "from": "javascript", "to": "javascript", "message_keys": ["type", "status"], "bidirectional": true}
  ],
  "tests": [
    {"name": "c", "language": "c", "globs": ["test/*.c"], "route_to": ["core"]},
    {"name": "python", "language": "python", "globs": ["test/*.py"], "route_to": ["python", "core"]},
    {"name": "javascript", "language": "javascript", "globs": ["test/*.js"], "route_to": ["javascript"]}
  ],
  "components": [
    {"name": "core", "paths": ["src/**"]},
    {"name": "frontends", "paths": ["py/**", "js/**", "ui/**"]}
  ],
  "named_entries": [
    {"name": "entries", "kind": "call_string_arg", "functions": ["core_register"], "argument": 1, "globs": ["src/**/*.c"]}
  ],
  "parity": [
    {
      "name": "package-api",
      "members": [
        {"label": "python", "source": "package", "package": "python"},
        {"label": "javascript", "source": "package", "package": "npm"}
      ],
      "case": "snake",
      "enforce": true
    }
  ],
  "constraints": {
    "REQUIRED-MAPPED-PATHS": {
      "kind": "required_paths",
      "paths": [
        "src/core.c",
        "src/core.h",
        "py/sample/api.py",
        "js/runtime.js",
        "ui/Widget.vue"
      ],
      "owner": "architecture",
      "rationale": "Reviewed source paths remain inside the configured Map scope."
    },
    "REQUIRED-SYMBOLS-CORE": {
      "kind": "required_symbols",
      "layer": "core",
      "symbols": [
        "core_add"
      ],
      "owner": "architecture",
      "rationale": "Reviewed core symbols remain present."
    },
    "REQUIRED-SYMBOLS-PYTHON": {
      "kind": "required_symbols",
      "layer": "python",
      "symbols": [
        "Ops.add"
      ],
      "owner": "architecture",
      "rationale": "Reviewed python symbols remain present."
    },
    "REQUIRED-SYMBOLS-JAVASCRIPT": {
      "kind": "required_symbols",
      "layer": "javascript",
      "symbols": [
        "ops.nested.mul"
      ],
      "owner": "architecture",
      "rationale": "Reviewed javascript symbols remain present."
    },
    "REQUIRED-FILE-EDGE-001": {
      "kind": "required_file_edge",
      "edge_kind": "import",
      "source": "js/main.js",
      "target": "js/worker.js",
      "owner": "architecture",
      "rationale": "The reviewed file dependency remains present.",
      "name": "./worker.js"
    },
    "REQUIRED-FILE-EDGE-002": {
      "kind": "required_file_edge",
      "edge_kind": "bridge:python-abi",
      "source": "py/**",
      "target": "src/core.c",
      "owner": "architecture",
      "rationale": "The reviewed file dependency remains present.",
      "name": "core_add"
    },
    "REQUIRED-BRIDGE-PYTHON-ABI": {
      "kind": "required_bridge",
      "bridge": "python-abi",
      "owner": "architecture",
      "rationale": "The reviewed bridge remains connected."
    },
    "REQUIRED-BRIDGE-JS-ABI": {
      "kind": "required_bridge",
      "bridge": "js-abi",
      "owner": "architecture",
      "rationale": "The reviewed bridge remains connected."
    },
    "REQUIRED-BRIDGE-JS-BINDING": {
      "kind": "required_bridge",
      "bridge": "js-binding",
      "owner": "architecture",
      "rationale": "The reviewed bridge remains connected."
    },
    "REQUIRED-BRIDGE-WORKER": {
      "kind": "required_bridge",
      "bridge": "worker",
      "owner": "architecture",
      "rationale": "The reviewed bridge remains connected."
    },
    "REQUIRED-ENTRYPOINT-001": {
      "kind": "required_package_entrypoint",
      "package": "npm",
      "route": "main",
      "owner": "architecture",
      "rationale": "The reviewed package entrypoint remains present.",
      "target": "js/index.js"
    },
    "REQUIRED-TEST-ROUTE-001": {
      "kind": "required_test_route",
      "group": "c",
      "target": "src/core.c",
      "owner": "architecture",
      "rationale": "The reviewed static test route remains present."
    },
    "REQUIRED-TEST-ROUTE-002": {
      "kind": "required_test_route",
      "group": "python",
      "target": "py/**",
      "owner": "architecture",
      "rationale": "The reviewed static test route remains present."
    },
    "PROVIDER-SURFACE-JS-ABI": {
      "declared": [
        "core_add",
        "core_mul",
        "core_unused"
      ],
      "forbid_unregistered": true,
      "forbid_unresolved": true,
      "forbid_ambiguous": true,
      "kind": "provider_surface",
      "surface": "js-abi",
      "owner": "architecture",
      "rationale": "The reviewed provider surface remains declared and resolvable."
    },
    "PROVIDER-SURFACE-JS-BINDING": {
      "declared": [
        "core_add",
        "core_mul"
      ],
      "forbid_unregistered": true,
      "forbid_unresolved": true,
      "forbid_ambiguous": true,
      "kind": "provider_surface",
      "surface": "js-binding",
      "owner": "architecture",
      "rationale": "The reviewed provider surface remains declared and resolvable."
    },
    "FORBIDDEN-REPOSITORY-PATHS": {
      "kind": "forbidden_paths",
      "paths": [
        "js/legacy*.js"
      ],
      "owner": "architecture",
      "rationale": "Deprecated repository paths remain absent."
    },
    "FORBIDDEN-SYMBOLS-CORE": {
      "kind": "forbidden_symbols",
      "layer": "core",
      "symbols": [
        "legacy_core"
      ],
      "owner": "architecture",
      "rationale": "Forbidden core symbols remain absent."
    }
  }
}
