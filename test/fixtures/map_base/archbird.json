{
  "schema_version": 1,
  "project": "map-base",
  "description": "Native aggregate map fixture.",
  "layers": [
    {
      "name": "javascript",
      "role": "frontend",
      "language": "javascript",
      "globs": ["js/**/*.js"]
    },
    {
      "name": "python",
      "role": "frontend",
      "language": "python",
      "globs": ["py/**/*.py"],
      "import_roots": ["py"]
    }
  ],
  "components": [
    {
      "name": "javascript",
      "paths": ["js/**"]
    },
    {
      "name": "python",
      "paths": ["py/**"]
    }
  ],
  "limits": {
    "compact_symbols": 7,
    "compact_edge_names": 9
  }
}
