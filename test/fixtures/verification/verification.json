{
  "schema_version": 1,
  "suite": "portable-verification",
  "description": "Portable failing fixture for typed facts, architecture relations, attestations, waivers, and ratchets.",
  "policy_date": "2026-07-11",
  "projects": {
    "reference": {
      "config": "reference/archbird.json",
      "revision": "fixture-v1",
      "profile": "cpu-int32",
      "capabilities": ["shape"],
      "parameters": {"rank_limit": 8}
    },
    "subject": {
      "config": "subject/archbird.json",
      "revision": "fixture-v1",
      "profile": "cpu-int32",
      "capabilities": ["shape"],
      "parameters": {"rank_limit": 8}
    }
  },
  "extractors": {
    "reference.ops": {
      "kind": "python_enum",
      "project": "reference",
      "path": "spec.py",
      "class": "Ops"
    },
    "reference.required": {
      "kind": "python_set",
      "project": "reference",
      "path": "spec.py",
      "class": "GroupOp",
      "attribute": "Required"
    },
    "subject.ops": {
      "kind": "c_enum",
      "project": "subject",
      "path": "src/core.h",
      "name": "PortOps",
      "strip_prefix": "PORT_",
      "exclude": ["COUNT"]
    },
    "subject.values": {
      "kind": "c_designated_initializer",
      "project": "subject",
      "path": "src/core.c",
      "name": "op_values",
      "strip_prefix": "PORT_",
      "exclude": ["EXTRA"]
    },
    "subject.required": {
      "kind": "c_macro_set",
      "project": "subject",
      "path": "src/core.c",
      "call": "OPSET",
      "selector_argument": 0,
      "selector": "PORT_REQUIRED",
      "values_from_argument": 1,
      "strip_prefix": "PORT_"
    },
    "subject.test_routes": {
      "kind": "test_routes",
      "project": "subject",
      "group": "c"
    },
    "relation.actual": {
      "kind": "literal_relation",
      "rows": [
        {"source": "a", "kind": "import", "target": "b"},
        {"source": "b", "kind": "call", "target": "c"},
        {"source": "c", "kind": "import", "target": "a"}
      ]
    },
    "relation.required": {
      "kind": "literal_relation",
      "rows": [
        {"source": "a", "kind": "import", "target": "b"}
      ]
    },
    "relation.forbidden": {
      "kind": "literal_relation",
      "rows": [
        {"source": "b", "kind": "call", "target": "c"}
      ]
    },
    "relation.allowed": {
      "kind": "literal_relation",
      "rows": [
        {"source": "a", "kind": "import", "target": "b"},
        {"source": "b", "kind": "call", "target": "c"}
      ]
    }
  },
  "mappings": {
    "ops": {
      "actual_to_expected": {"TIMES": "MUL"}
    }
  },
  "attestations": {
    "reference.behavior": {
      "project": "reference",
      "path": "reference.attestation.json"
    },
    "subject.behavior": {
      "project": "subject",
      "path": "subject.attestation.json"
    }
  },
  "checks": [
    {
      "id": "PORT-OPS-SET",
      "assert": "mapped_set_equal",
      "severity": "error",
      "owner": "compiler-core",
      "rationale": "The port must account for every reference operation name.",
      "requirement": "SPEC-OPS",
      "expected": "reference.ops",
      "actual": "subject.ops",
      "mapping": "ops"
    },
    {
      "id": "PORT-OPS-VALUES",
      "assert": "mapped_values_equal",
      "severity": "error",
      "owner": "compiler-core",
      "rationale": "Serialized operation values are a declared compatibility contract.",
      "requirement": "SPEC-OPS-VALUES",
      "expected": "reference.ops",
      "actual": "subject.values",
      "mapping": "ops"
    },
    {
      "id": "PORT-GROUP-REQUIRED",
      "assert": "mapped_set_equal",
      "severity": "error",
      "owner": "compiler-core",
      "rationale": "Required group membership must match the reference.",
      "expected": "reference.required",
      "actual": "subject.required",
      "mapping": "ops"
    },
    {
      "id": "PORT-GROUP-SUBSET",
      "assert": "subset",
      "severity": "warning",
      "owner": "compiler-core",
      "rationale": "Subject group members must come from the mapped reference inventory.",
      "expected": "reference.ops",
      "actual": "subject.required",
      "mapping": "ops"
    },
    {
      "id": "REFERENCE-OPS-CARDINALITY",
      "assert": "cardinality",
      "severity": "error",
      "owner": "specification",
      "rationale": "The fixture reference intentionally contains three operations.",
      "actual": "reference.ops",
      "exact": 3
    },
    {
      "id": "ARCH-REQUIRED-EDGE",
      "assert": "required_edges",
      "severity": "error",
      "owner": "architecture",
      "rationale": "The required relation must remain present.",
      "expected": "relation.required",
      "actual": "relation.actual"
    },
    {
      "id": "ARCH-FORBIDDEN-EDGE",
      "assert": "forbidden_edges",
      "severity": "error",
      "owner": "architecture",
      "rationale": "The forbidden relation must not appear.",
      "expected": "relation.forbidden",
      "actual": "relation.actual"
    },
    {
      "id": "ARCH-ALLOWED-EDGES",
      "assert": "allowed_edges",
      "severity": "error",
      "owner": "architecture",
      "rationale": "Every relation must fit the reviewed layer matrix.",
      "expected": "relation.allowed",
      "actual": "relation.actual"
    },
    {
      "id": "ARCH-ACYCLIC",
      "assert": "acyclic",
      "severity": "error",
      "owner": "architecture",
      "rationale": "The dependency relation must remain acyclic.",
      "actual": "relation.actual"
    },
    {
      "id": "PORT-TEST-ROUTES",
      "assert": "min_test_routes",
      "severity": "error",
      "owner": "verification",
      "rationale": "At least one core test route must remain connected.",
      "actual": "subject.test_routes",
      "min": 1,
      "required_routes": ["src/core.c"]
    },
    {
      "id": "PORT-BEHAVIOR",
      "assert": "attestation_equal",
      "severity": "error",
      "owner": "verification",
      "rationale": "Every applicable reference case must agree across required subject routes.",
      "requirement": ["SHAPE-001", "NUMERIC-001"],
      "expected": "reference.behavior",
      "actual": "subject.behavior",
      "reference_route": "reference",
      "required_routes": ["python", "browser"]
    }
  ],
  "waivers": [
    {
      "id": "KNOWN-GROUP-EXTRA",
      "check": "PORT-GROUP-REQUIRED",
      "comparison": "extra",
      "key": "EXTRA",
      "owner": "compiler-core",
      "rationale": "Fixture-only reviewed extension used to exercise waiver policy.",
      "expires_on": "2026-12-31"
    }
  ]
}
