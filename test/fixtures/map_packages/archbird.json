{
  "schema_version": 2,
  "project": "map-packages",
  "layers": [
    {
      "name": "core",
      "role": "core",
      "language": "c",
      "globs": ["src/**/*.c", "include/**/*.h"]
    },
    {
      "name": "javascript",
      "role": "frontend",
      "language": "javascript",
      "globs": ["js/src/**/*.js"]
    },
    {
      "name": "python",
      "role": "frontend",
      "language": "python",
      "globs": ["py/**/*.py"],
      "import_roots": ["py"]
    },
    {
      "name": "r",
      "role": "frontend",
      "language": "r",
      "globs": ["r/R/**/*.R"]
    },
    {
      "name": "worker",
      "role": "frontend",
      "language": "javascript",
      "globs": ["js/worker/**/*.js"]
    }
  ],
  "packages": [
    {
      "name": "npm",
      "kind": "npm",
      "path": "js/package.json",
      "layer": "javascript",
      "entries": ["js/src/index.js"]
    },
    {
      "name": "python-modern",
      "kind": "python",
      "path": "py/pyproject.toml",
      "layer": "python",
      "entries": ["py/pkg/__init__.py"]
    },
    {
      "name": "python-legacy",
      "kind": "python",
      "path": "legacy/setup.py",
      "layer": "python",
      "entries": ["py/legacy/__init__.py"]
    },
    {
      "name": "r",
      "kind": "r",
      "path": "r/NAMESPACE",
      "layer": "r",
      "entries": ["r/R/package.R"]
    }
  ],
  "builds": [
    {"name": "make", "kind": "make", "path": "Makefile"},
    {"name": "npm", "kind": "npm", "path": "js/package.json"}
  ],
  "artifacts": [
    {
      "name": "native",
      "output": "build/libexample.so",
      "inputs": ["js/src/**"],
      "loaded_by": [
        {"paths": ["Makefile"], "pattern": "libexample\\.so"}
      ],
      "builds": [{"source": "Makefile", "target": "all"}]
    },
    {
      "name": "bundle",
      "output": "build/bundle.js",
      "inputs": ["Makefile"],
      "loaded_by": [
        {"paths": ["js/package.json"], "pattern": "src/index\\.js"}
      ],
      "builds": [{"source": "Makefile", "target": "browser"}]
    }
  ],
  "bridges": [
    {
      "name": "python-c",
      "kind": "abi",
      "from": "python",
      "to": "core",
      "prefixes": ["poly_"],
      "ignore": ["poly_ignore"],
      "providers": [
        {
          "kind": "make_variable",
          "path": "Makefile",
          "variable": "WASM_EXPORTS",
          "pattern": "(_?poly_[A-Za-z0-9_]+)"
        }
      ]
    },
    {
      "name": "python-js",
      "kind": "binding",
      "from": "python",
      "to": "javascript",
      "providers": [{"kind": "exports", "path": "js/src/**"}]
    },
    {
      "name": "browser-worker",
      "kind": "message",
      "from": "javascript",
      "to": "worker",
      "bidirectional": true,
      "message_keys": ["type", "status"]
    }
  ],
  "tests": [
    {
      "name": "c",
      "language": "c",
      "globs": ["test/test_*.c"],
      "route_to": ["core"]
    },
    {
      "name": "python",
      "language": "python",
      "globs": ["test/test_*.py"],
      "route_to": ["python", "core"]
    },
    {
      "name": "javascript",
      "language": "javascript",
      "globs": ["test/test_*.js"],
      "route_to": ["javascript"],
      "case_routes": [
        {"selector": "configured case", "to": "src/core.c"}
      ]
    },
    {
      "name": "r",
      "language": "r",
      "globs": ["test/test_*.R"],
      "route_to": ["r"]
    }
  ],
  "named_entries": [
    {
      "name": "entrypoints",
      "kind": "call_string_arg",
      "functions": ["poly_register_entrypoint"],
      "argument": 1,
      "globs": ["src/**/*.c"]
    }
  ],
  "parity": [
    {
      "name": "core-bridge",
      "members": [
        {
          "label": "core",
          "source": "symbols",
          "layer": "core",
          "include": ["^poly_"],
          "kinds": ["function"]
        },
        {"label": "bridge", "source": "bridge", "bridge": "python-c"}
      ],
      "strip_prefixes": ["poly_"],
      "case": "snake",
      "enforce": true
    }
  ],
  "constraints": {
    "REQUIRED-MAPPED-PATHS": {
      "kind": "required_paths",
      "paths": [
        "src/core.c",
        "py/pkg/api.py",
        "js/src/index.js"
      ],
      "owner": "architecture",
      "rationale": "Reviewed source paths remain inside the configured Map scope."
    },
    "REQUIRED-SYMBOLS-CORE": {
      "kind": "required_symbols",
      "layer": "core",
      "symbols": [
        "poly_add"
      ],
      "owner": "architecture",
      "rationale": "Reviewed core symbols remain present."
    },
    "REQUIRED-FILE-EDGE-001": {
      "kind": "required_file_edge",
      "edge_kind": "bridge:*",
      "source": "py/**/*.py",
      "target": "src/**/*.c",
      "owner": "architecture",
      "rationale": "The reviewed file dependency remains present.",
      "name": "poly_*"
    },
    "REQUIRED-BRIDGE-BROWSER-WORKER": {
      "kind": "required_bridge",
      "bridge": "browser-worker",
      "owner": "architecture",
      "rationale": "The reviewed bridge remains connected."
    },
    "REQUIRED-ENTRYPOINT-001": {
      "kind": "required_package_entrypoint",
      "package": "npm",
      "route": "main",
      "owner": "architecture",
      "rationale": "The reviewed package entrypoint remains present.",
      "target": "src/index.js"
    },
    "REQUIRED-TEST-ROUTE-001": {
      "kind": "required_test_route",
      "group": "c",
      "target": "src/core.c",
      "owner": "architecture",
      "rationale": "The reviewed static test route remains present."
    },
    "PROVIDER-SURFACE-PYTHON-C": {
      "declared": [
        "poly_add"
      ],
      "kind": "provider_surface",
      "surface": "python-c",
      "owner": "architecture",
      "rationale": "The reviewed provider surface remains declared and resolvable."
    },
    "FORBIDDEN-REPOSITORY-PATHS": {
      "kind": "forbidden_paths",
      "paths": [
        "legacy-forbidden/**"
      ],
      "owner": "architecture",
      "rationale": "Deprecated repository paths remain absent."
    },
    "FORBIDDEN-SYMBOLS-CORE": {
      "kind": "forbidden_symbols",
      "layer": "core",
      "symbols": [
        "forbidden_symbol"
      ],
      "owner": "architecture",
      "rationale": "Forbidden core symbols remain absent."
    }
  }
}
