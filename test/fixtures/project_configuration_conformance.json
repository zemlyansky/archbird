{
  "schema_version": 1,
  "cases": [
    {
      "id": "minimal",
      "valid": true,
      "configuration": {
        "schema_version": 2,
        "project": "conformance",
        "layers": [
          {"name": "c", "language": "c", "globs": ["src/**/*.c"]}
        ]
      }
    },
    {
      "id": "all-projection-operators",
      "valid": true,
      "configuration": {
        "schema_version": 2,
        "project": "conformance",
        "layers": [
          {"name": "c", "language": "c", "globs": ["src/**/*.c"]}
        ],
        "projections": {
          "artifact-routes": {"select": "artifact_routes", "artifacts": ["library"]},
          "component-edges": {"select": "component_edges", "kinds": ["call"]},
          "component-membership": {"select": "component_membership", "components": ["core"], "include": ["src/**"]},
          "constant-memberships": {"select": "constant_memberships", "container": "Flags", "paths": ["src/**"], "strip_prefix": "FLAG_"},
          "constant-values": {"select": "constant_values", "container": "Opcode", "paths": ["src/**"], "kinds": ["enum-member"], "exclude": ["RESERVED"]},
          "file-edges": {"select": "file_edges", "from_paths": ["src/**"], "to_paths": ["include/**"], "kinds": ["import"], "kind_patterns": ["imp*"], "name_patterns": ["api*"]},
          "file-metrics": {"select": "file_metrics", "metric": "bytes", "include": ["src/**"]},
          "inventory-paths": {"select": "inventory_paths", "exclude": ["vendor/**"]},
          "macro-members": {"select": "macro_members", "call": "REGISTER", "selector": "public", "paths": ["src/**"], "selector_argument": 0, "values_from_argument": 1, "strip_prefix": "OP_"},
          "mapped-paths": {"select": "mapped_paths", "paths": ["src/**"], "strip_prefix": "src/"},
          "package-entrypoints": {"select": "package_entrypoints", "packages": ["core"], "routes": ["main"], "target_paths": ["src/**"]},
          "package-exports": {"select": "package_exports", "packages": ["core"], "name_patterns": ["open*"]},
          "provider-surface": {"select": "provider_surface", "name": "public", "include": ["open*"]},
          "search-domain": {"select": "search_domain"},
          "symbols": {"select": "symbols", "paths": ["include/**"], "kinds": ["function"], "names": ["open"], "name_patterns": ["op*"], "layer": "c", "public_only": true, "strip_prefix": "api_"},
          "test-routes": {"select": "test_routes", "group": "native", "paths": ["test/**"], "selectors": ["test_*"], "target_paths": ["src/**"], "configured_only": true},
          "test-selectors": {"select": "test_selectors", "group": "native", "paths": ["test/**"], "selectors": ["test_*"], "strip_suffix": "_case"}
        },
        "queries": {
          "full-context": {
            "projection": "search-domain",
            "context": {
              "profile": "architecture",
              "provenance": ["derived", "asserted", "observed"],
              "confidence": ["exact", "candidate", "conservative", "unresolved"],
              "max_seed_distance": 3,
              "candidate": "expand",
              "conservative": "collapse",
              "quotas": {"files": 5, "symbol_calls": 6, "symbol_references": 7, "test_matches": 8},
              "offsets": {"files": 1, "symbol_calls": 2, "symbol_references": 3, "test_matches": 4}
            }
          }
        }
      }
    },
    {
      "id": "literal-operands",
